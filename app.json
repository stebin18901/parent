{
  "expo": {
    "name": "parent-social-app",
    "slug": "parent-social-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "https://firebasestorage.googleapis.com/v0/b/dreamprojects-cda5b.appspot.com/o/logo%2Flogo.png?alt=media&token=1002c533-d79a-4bc8-897d-66132723272c",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "https://firebasestorage.googleapis.com/v0/b/dreamprojects-cda5b.appspot.com/o/logo%2Flogo.png?alt=media&token=1002c533-d79a-4bc8-897d-66132723272c",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow YourAppName to access the microphone for live subtitles.",
        "NSSpeechRecognitionUsageDescription": "Allow YourAppName to use speech recognition for real-time team communication."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "https://firebasestorage.googleapis.com/v0/b/dreamprojects-cda5b.appspot.com/o/logo%2Flogo.png?alt=media&token=1002c533-d79a-4bc8-897d-66132723272c",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.parentsocialapp"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow YourAppName to access the microphone for live subtitles.",
          "speechRecognitionPermission": "Allow YourAppName to use speech recognition for real-time team communication."
        }
      ],
      "./plugins/withAndroidManifestFix",
      "./plugins/withAndroidXOnly"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3454e6fb-9a94-4a77-a7d8-50a6d02fa9fc"
      }
    }
  }
}